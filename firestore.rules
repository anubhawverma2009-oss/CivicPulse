rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Allow public get for user profiles (names, roles, etc. are public in civic platform)
      allow get: if true;
      allow list: if isSignedIn(); 
      
      allow create: if (
        (isSignedIn() && request.auth.uid == userId) || 
        userId.matches('^user-[a-zA-Z0-9]+$') // Allow seeding/accessing demo users
      );
      
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        userId.matches('^user-[a-zA-Z0-9]+$')
      );
    }

    // Issues Collection
    match /issues/{issueId} {
      // Allow public read for the civic feed (crucial for transparency)
      allow list, get: if true;
      
      allow create: if (
        (isSignedIn() && incoming().authorId == request.auth.uid) || 
        issueId.matches('^issue-[0-9]+$') // Allow seeding demo issues
      );
      
      allow update: if (
        (isSignedIn() && (
          (existing().authorId == request.auth.uid) ||
          // Community and authority actions
          incoming().diff(existing()).affectedKeys().hasOnly(['votedUserIds', 'pollVotes', 'votedResolutionUserIds', 'resolutionVotes', 'status', 'comments', 'peerEvidence', 'responses', 'likes', 'updatedAt', 'resolvedAt'])
        )) ||
        issueId.matches('^issue-[0-9]+$')
      );
      
      allow delete: if (
        (isSignedIn() && existing().authorId == request.auth.uid) ||
        issueId.matches('^issue-[0-9]+$')
      );
    }
  }
}
