rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      allow get, list: if isSignedIn(); // Allow reading profile, maybe restrict to isOwner later
      allow create: if isSignedIn() && request.auth.uid == userId && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().uid == request.auth.uid;
    }

    // Issues Collection
    match /issues/{issueId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && existing().authorId == request.auth.uid;
      allow delete: if false; // Disallow deletion for now
    }
  }
}
